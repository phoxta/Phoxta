# --- Phoxta agent (the brain) ---
# agent-inbound edge function URL + Supabase anon key (gateway key).
PHOXTA_AGENT_URL=https://YOUR_REF.supabase.co/functions/v1/agent-inbound
SUPABASE_ANON_KEY=your-supabase-anon-key
# The business's agent public key (AI Agent -> Configure -> web widget key).
PHOXTA_AGENT_KEY=the-agent-public-key
# Multi-tenant: optionally map a Twilio number to a key (one per number):
# PHOXTA_KEY_+15551234567=another-business-public-key

# --- Voice transport ---
# Public hostname Twilio reaches (no scheme), e.g. ngrok in dev.
PUBLIC_HOST=YOUR-HOST.ngrok.app
PORT=8765

# Speech-to-text (Deepgram) and text-to-speech (Cartesia). Swap for your choice.
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22

# Twilio (number that receives calls; creds let Pipecat hang up cleanly).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- In-browser voice widget (WebRTC /offer) ---
# CORS allow-list for the SPA origin(s) that embed the widget (CSV, or * in dev).
ALLOWED_ORIGINS=*
# STUN/TURN servers for NAT traversal (CSV). A public STUN works for most setups;
# add a TURN server for restrictive networks. (The SPA points at this server via
# VITE_VOICE_SERVER_URL=https://<this-host> in the front-end env.)
ICE_SERVERS=stun:stun.l.google.com:19302

# --- Optional, key-free call-quality upgrades (off by default) ---
# Natural end-of-turn detection (local ONNX model, no API key) so the agent
# waits for the caller to truly finish instead of jumping in on a pause.
# Requires: pip install onnxruntime
# SMART_TURN=1
# RNNoise background-noise suppression on inbound audio -> cleaner STT on noisy
# lines. Requires the rnnoise native dependency.
# DENOISE=1
# Record calls: capture caller+agent audio, save a WAV under ./recordings, and
# upload it to a Supabase Storage bucket ("call-recordings") via a signed URL
# (agent-inbound mints it; service-role key stays server-side), then link it onto
# the call log. The bucket is created public on first use — switch it to private
# + signed download URLs for production. (Check call-recording consent laws.)
# RECORD_CALLS=1
# (DTMF keypad capture is always on: presses are forwarded to the agent as
#  messages, e.g. for "press 1 for sales", verification codes, or IVR menus.)
